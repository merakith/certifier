# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# PRIVATE_KEY: The private key of the wallet used to pay for gas (backend minting)
PRIVATE_KEY=""

# CONTRACT_ADDRESS: The address of the deployed ERC721 certificate contract
CONTRACT_ADDRESS=""

# RPC_URL: The URL of the Ethereum node (e.g., http://localhost:8545 for Hardhat)
RPC_URL=""
